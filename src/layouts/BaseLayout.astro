---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCta from '../components/MobileStickyCta.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonical?: string;
	image?: string;
	noindex?: boolean;
	schema?: Record<string, unknown> | Array<Record<string, unknown>>;
	ogType?: 'website' | 'article';
	imageAlt?: string;
	publishedTime?: string;
	modifiedTime?: string;
}

const {
	title,
	description,
	canonical = Astro.url.pathname,
	image = '/images/hero-panneau-solaire-alpes-maritimes.png',
	noindex = false,
	schema,
	ogType = 'website',
	imageAlt = 'Villa azuréenne équipée de panneaux solaires',
	publishedTime,
	modifiedTime,
} = Astro.props;

const siteUrl = 'https://panneau-solaire-alpes-maritimes.fr';
const canonicalObject = new URL(canonical, siteUrl);
canonicalObject.search = '';
canonicalObject.hash = '';
if (canonicalObject.pathname !== '/' && !canonicalObject.pathname.endsWith('/')) {
	canonicalObject.pathname += '/';
}
const canonicalUrl = canonicalObject.toString();
const imageUrl = new URL(image, siteUrl).toString();
const preloadHero = canonicalObject.pathname === '/';
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0C4A6E" />
		<meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		{preloadHero && (
			<link
				rel="preload"
				as="image"
				href="/images/hero-panneau-solaire-alpes-maritimes.png"
				type="image/png"
				fetchpriority="high"
			/>
		)}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@500;600;700&family=Figtree:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content="fr_FR" />
		<meta property="og:site_name" content="Panneau Solaire Alpes-Maritimes" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:alt" content={imageAlt} />
		{ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<meta name="twitter:image:alt" content={imageAlt} />
		{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
		<script defer src="https://nhmvgsrwhjsjnpncpiaj.supabase.co/functions/v1/analytics-collect?script=1"></script>
	</head>
	<body class:list={{ 'has-mobile-cta': canonicalObject.pathname !== '/devis/' }}>
		<a class="skip-link" href="#contenu">Aller au contenu</a>
		<Header />
		<main id="contenu">
			<slot />
		</main>
		<Footer />
		<MobileStickyCta />
	</body>
</html>
