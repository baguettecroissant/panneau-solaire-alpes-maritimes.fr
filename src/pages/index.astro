---
import BaseLayout from '../layouts/BaseLayout.astro';
import PremiumSolarSimulator from '../components/PremiumSolarSimulator.astro';
import LeadForm from '../components/LeadForm.astro';
import { communes } from '../data/site';

const topCities = communes.slice(0, 8);
const referenceYield = 1450;
const production3 = referenceYield * 3;
const production6 = referenceYield * 6;
const production9 = referenceYield * 9;
const faqs = [
	['Quel budget prévoir pour des panneaux solaires dans les Alpes-Maritimes ?', 'Pour une installation premium, comptez généralement 8 500 à 11 000 € TTC pour 3 kWc, 14 000 à 18 000 € pour 6 kWc et 18 000 à 24 000 € pour 9 kWc. La toiture, le matériel, la batterie et l’accès au chantier font varier le devis.'],
	['Quelle production attendre à Nice ?', 'Un scénario indicatif de 6 kWc bien orienté peut approcher 8 700 kWh par an dans le 06. Une étude de toiture doit corriger ce repère selon la pente, les ombres, la ventilation et l’orientation réelles.'],
	['Le sel marin et la chaleur abîment-ils les panneaux ?', 'Le matériel correctement sélectionné résiste aux conditions littorales. À proximité de la mer, exigez des composants adaptés à la corrosion, une ventilation suffisante et des fixations dimensionnées pour le vent.'],
	['Comment choisir un installateur dans le 06 ?', 'Vérifiez la qualification QualiPV RGE, l’assurance décennale couvrant le photovoltaïque, les références exactes du matériel et une étude d’ombrage documentée.'],
	['Une batterie de 10 kWh est-elle rentable ?', 'Elle devient intéressante lorsque le surplus de journée est fréquent et que la villa consomme beaucoup le soir. Comparez toujours un scénario avec et sans stockage.'],
	['Peut-on alimenter piscine, climatisation et voiture électrique ?', 'Oui. Ces usages coïncident souvent avec la production solaire azuréenne et peuvent être pilotés pour augmenter l’autoconsommation.']
];
const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		'@id': 'https://panneau-solaire-alpes-maritimes.fr/#organization',
		name: 'Panneau Solaire Alpes-Maritimes',
		url: 'https://panneau-solaire-alpes-maritimes.fr/',
		description: 'Information photovoltaïque, simulation et mise en relation pour des projets solaires dans les Alpes-Maritimes.'
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'Étude et comparaison de devis photovoltaïques dans les Alpes-Maritimes',
		provider: { '@id': 'https://panneau-solaire-alpes-maritimes.fr/#organization' },
		areaServed: { '@type': 'AdministrativeArea', name: 'Alpes-Maritimes' },
		serviceType: 'Mise en relation pour un projet photovoltaïque premium'
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(([question, answer]) => ({
			'@type': 'Question',
			name: question,
			acceptedAnswer: { '@type': 'Answer', text: answer }
		}))
	}
];
---

<BaseLayout
	title="Panneaux Solaires Alpes-Maritimes (06) — Installation Premium & Devis 2026"
	description="Panneaux solaires premium dans les Alpes-Maritimes : prix 3 à 12 kWc, production azuréenne, batterie et devis QualiPV RGE."
	schema={schema}
>
	<section class="hero">
		<div class="container hero-inner">
			<div class="hero-copy">
				<div class="hero-badge"><span></span> Côte d’Azur · 2 800 h de soleil par an</div>
				<h1>Panneaux solaires dans le 06,<br /><em>l’énergie devient patrimoine.</em></h1>
				<p class="hero-lead">
					Modules N-type full black, micro-onduleurs Enphase et batterie LFP : une étude haut de gamme pour produire, piloter et valoriser votre villa azuréenne.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="/devis/">Recevoir mon étude gratuite →</a>
					<a class="button button-hero-secondary" href="#simulateur">Lancer le simulateur</a>
				</div>
				<div class="hero-trust">
					<span><i>✓</i> Installateurs QualiPV RGE</span>
					<span><i>✓</i> Étude sans engagement</span>
					<span><i>✓</i> Expertise locale 06</span>
				</div>
			</div>
			<div class="hero-dashboard" aria-label="Scénario indicatif de production solaire d’une villa à Nice">
				<div class="dashboard-top">
					<span>Scénario villa · Nice 9 kWc</span>
					<div class="live-badge"><span></span> Production</div>
				</div>
				<div class="dashboard-production">
					<small>Puissance instantanée</small>
					<strong>7,34 <span>kW</span></strong>
				</div>
				<div class="power-chart" aria-hidden="true">
					<span style="height: 15%"></span><span style="height: 28%"></span><span style="height: 44%"></span>
					<span style="height: 62%"></span><span style="height: 79%"></span><span style="height: 94%"></span>
					<span style="height: 100%"></span><span style="height: 95%"></span><span style="height: 82%"></span>
					<span style="height: 63%"></span><span style="height: 39%"></span><span style="height: 18%"></span>
				</div>
				<div class="dashboard-grid">
					<div><small>Aujourd’hui</small><strong>43,8 kWh</strong></div>
					<div><small>Autoconsommé</small><strong>74 %</strong></div>
					<div><small>Autonomie</small><strong>68 %</strong></div>
					<div><small>Valeur énergie</small><strong>10,42 €</strong></div>
				</div>
			</div>
		</div>
		<div class="container hero-stats">
			<div class="hero-stat"><strong>1 450</strong><span>kWh/kWc/an · repère Côte d’Azur</span></div>
			<div class="hero-stat"><strong>6–12 kWc</strong><span>format privilégié pour une villa</span></div>
			<div class="hero-stat"><strong>30 ans</strong><span>garantie linéaire disponible</span></div>
			<div class="hero-stat"><strong>{communes.length}</strong><span>communes couvertes dans le 06</span></div>
		</div>
	</section>

	<section class="section" style="padding-top: 150px">
		<div class="container">
			<div class="section-heading center">
				<span class="eyebrow eyebrow-amber">Ingénierie solaire premium</span>
				<h2>La performance, sans compromis esthétique.</h2>
				<p>Chaque détail relie technologie, architecture et confort : toiture, exposition, piscine, climatisation, recharge électrique et stockage.</p>
			</div>
			<div class="feature-grid">
				<article class="feature-card"><div class="feature-icon">01</div><h3>Étude de production</h3><p>Orientation, pente, ombrages et profil électrique rapprochés d’un modèle de production adapté au 06.</p></article>
				<article class="feature-card"><div class="feature-icon">02</div><h3>Intégration full black</h3><p>Une finition sobre et homogène, avec câblage discret et calepinage aligné sur les lignes de la villa.</p></article>
				<article class="feature-card"><div class="feature-icon">03</div><h3>Pilotage intelligent</h3><p>Piscine, climatisation, batterie LFP et borne de recharge coordonnés avec le surplus solaire.</p></article>
			</div>
		</div>
	</section>

	<section id="simulateur" class="section section-white">
		<div class="container"><PremiumSolarSimulator city="Nice" yieldPerKwc={referenceYield} /></div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-heading">
				<span class="eyebrow">Puissance & budget 2026</span>
				<h2>Du 3 kWc discret au 12 kWc d’exception.</h2>
				<p>Des enveloppes réalistes pour du matériel premium, une installation QualiPV et un niveau de finition adapté aux propriétés azuréennes.</p>
			</div>
			<div class="price-grid">
				<article class="price-card">
					<span class="price-power">8 modules · 3 kWc</span><h3>Maison élégante</h3>
					<strong class="price-amount">8 500 – 11 000 €</strong>
					<div class="price-meta">Production indicative · {production3.toLocaleString('fr-FR')} kWh/an</div>
					<p>Pour réduire le talon de consommation avec une intégration compacte.</p>
					<ul class="check-list"><li>Modules N-type full black</li><li>Monitoring connecté</li><li>Surplus EDF OA</li></ul>
				</article>
				<article class="price-card featured">
					<div class="price-ribbon">Équilibre villa</div>
					<span class="price-power">16 modules · 6 kWc</span><h3>Villa avec piscine</h3>
					<strong class="price-amount">14 000 – 18 000 €</strong>
					<div class="price-meta">Production indicative · {production6.toLocaleString('fr-FR')} kWh/an</div>
					<p>Le format cohérent pour climatisation, piscine et usages familiaux.</p>
					<ul class="check-list"><li>Micro-onduleurs premium</li><li>Compatible batterie LFP</li><li>Pilotage multi-usages</li></ul>
				</article>
				<article class="price-card">
					<span class="price-power">24 modules · 9 kWc</span><h3>Grande propriété</h3>
					<strong class="price-amount">18 000 – 24 000 €</strong>
					<div class="price-meta">Production indicative · {production9.toLocaleString('fr-FR')} kWh/an</div>
					<p>Pour une villa fortement équipée et la recharge d’un véhicule électrique.</p>
					<ul class="check-list"><li>Onduleur hybride possible</li><li>Stockage 10–15 kWh</li><li>Supervision complète</li></ul>
				</article>
			</div>
			<p style="margin-top: 30px"><a class="text-link" href="/tarifs/">Comparer tous les équipements et options →</a></p>
		</div>
	</section>

	<section class="section section-forest">
		<div class="container performance-shell">
			<div class="performance-copy">
				<span class="eyebrow eyebrow-amber">Exemple modélisé · Nice</span>
				<h2>Une production alignée sur le rythme de votre villa.</h2>
				<p>Le soleil azuréen coïncide avec la filtration de piscine, la climatisation et la recharge de journée. Le pilotage transforme ces usages en valeur énergétique.</p>
				<div class="metric-row">
					<div class="metric-box"><strong>8 700 kWh</strong><span>projection indicative · 6 kWc</span></div>
					<div class="metric-box"><strong>74 %</strong><span>autoconsommation pilotée</span></div>
					<div class="metric-box"><strong>1 720 €</strong><span>gain annuel indicatif</span></div>
					<div class="metric-box"><strong>10 kWh</strong><span>batterie type à comparer</span></div>
				</div>
			</div>
			<div class="monthly-dashboard">
				<div class="monthly-dashboard-header"><div><small>Production annuelle modélisée</small><br /><strong>6 kWc · Nice</strong></div><div class="live-badge"><span></span> 2026</div></div>
				<div class="month-bars" aria-label="Production mensuelle indicative">
					<div class="month"><i style="height: 42%"></i><span>JAN</span></div><div class="month"><i style="height: 54%"></i><span>FÉV</span></div>
					<div class="month"><i style="height: 75%"></i><span>MAR</span></div><div class="month"><i style="height: 87%"></i><span>AVR</span></div>
					<div class="month"><i style="height: 96%"></i><span>MAI</span></div><div class="month"><i style="height: 100%"></i><span>JUN</span></div>
					<div class="month"><i style="height: 99%"></i><span>JUL</span></div><div class="month"><i style="height: 94%"></i><span>AOÛ</span></div>
					<div class="month"><i style="height: 81%"></i><span>SEP</span></div><div class="month"><i style="height: 66%"></i><span>OCT</span></div>
					<div class="month"><i style="height: 48%"></i><span>NOV</span></div><div class="month"><i style="height: 39%"></i><span>DÉC</span></div>
				</div>
				<div class="dashboard-legend"><span><i></i> Production photovoltaïque</span><span><i></i> Plateau solaire optimal</span></div>
			</div>
		</div>
	</section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading center"><span class="eyebrow eyebrow-amber">Mission en quatre phases</span><h2>De la toiture à l’autonomie pilotée.</h2></div>
			<div class="process-grid">
				<div class="process-step"><div class="step-number">01</div><h3>Qualification</h3><p>Toiture, consommation, piscine, climatisation et mobilité sont cadrées.</p></div>
				<div class="process-step"><div class="step-number">02</div><h3>Conception</h3><p>Production, puissance, autoconsommation, esthétique et batterie sont comparées.</p></div>
				<div class="process-step"><div class="step-number">03</div><h3>Installation</h3><p>Un professionnel QualiPV RGE pose, raccorde et documente la centrale.</p></div>
				<div class="process-step"><div class="step-number">04</div><h3>Pilotage</h3><p>Le monitoring orchestre chaque kWh entre la villa, la batterie et le réseau.</p></div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-heading"><span class="eyebrow">Ancrage Côte d’Azur</span><h2>{communes.length} communes, un potentiel solaire exceptionnel.</h2><p>De Nice à Cannes, d’Antibes à Menton et jusqu’à l’arrière-pays, chaque projet doit intégrer urbanisme, relief, vent et proximité du littoral.</p></div>
			<div class="city-grid">
				{topCities.map((city) => (
					<a class="city-card" href={`/panneau-solaire-${city.slug}/`}>
						<div class="city-card-header"><h3>{city.name}</h3><span class="postal-pill">{city.postalCodes[0]}</span></div>
						<p>≈ {referenceYield.toLocaleString('fr-FR')} kWh/kWc/an · {city.population.toLocaleString('fr-FR')} habitants</p>
						<div class="city-card-footer"><span>Étude premium locale</span><span>→</span></div>
					</a>
				))}
			</div>
			<p style="margin-top:30px"><a class="text-link" href="/communes/">Explorer toutes les communes du 06 →</a></p>
		</div>
	</section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading"><span class="eyebrow eyebrow-amber">Guides experts</span><h2>Décider avec des données, pas avec un discours commercial.</h2><p>Prix, aides, stockage et sélection RGE : nos dossiers pour sécuriser un investissement solaire premium.</p></div>
			<div class="guide-grid">
				<a class="guide-card" href="/guides/prix-panneaux-solaires-premium-06/"><div class="guide-image"><img src="/images/guide-prix-alpes-maritimes.webp" alt="Guide prix panneaux solaires premium" width="1600" height="900" loading="lazy"/><span class="guide-tag">Prix 2026</span></div><div class="guide-content"><h3>Prix du solaire premium dans le 06</h3><p>Budgets 3, 6, 9 et 12 kWc, composants et postes de coût.</p><div class="guide-meta"><span>8 min</span><span>Lire →</span></div></div></a>
				<a class="guide-card" href="/guides/autoconsommation-batterie-10-kwh/"><div class="guide-image"><img src="/images/guide-batterie-solaire.webp" alt="Batterie solaire lithium pour villa" width="1600" height="900" loading="lazy"/><span class="guide-tag">Stockage</span></div><div class="guide-content"><h3>Batterie 10 kWh et autonomie</h3><p>Comparer stockage, pilotage et usages nocturnes de la villa.</p><div class="guide-meta"><span>9 min</span><span>Lire →</span></div></div></a>
				<a class="guide-card" href="/guides/installateur-solaire-rge-qualipv-06/"><div class="guide-image"><img src="/images/guide-installateur-rge.webp" alt="Installateur solaire QualiPV RGE" width="1600" height="900" loading="lazy"/><span class="guide-tag">Qualité</span></div><div class="guide-content"><h3>Choisir un installateur QualiPV</h3><p>Assurances, étude technique, garanties et références à vérifier.</p><div class="guide-meta"><span>7 min</span><span>Lire →</span></div></div></a>
			</div>
		</div>
	</section>

	<section class="section"><div class="container"><LeadForm compact={true} /></div></section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading center"><span class="eyebrow">Questions fréquentes</span><h2>Précisions techniques, réponses claires.</h2></div>
			<div class="faq-list">{faqs.map(([question, answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}</div>
		</div>
	</section>
</BaseLayout>
